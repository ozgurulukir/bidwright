  description      String         @default("")
  category         String         @default("")
  scope            String         @default("global")
  projectId        String?
  revisionId       String?
  revision         QuoteRevision? @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  sourceScheduleId String?
  effectiveDate    String?
  expiryDate       String?
  defaultMarkup    Float          @default(0)
  autoCalculate    Boolean        @default(true)
  metadata         Json           @default("{}")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tiers RateScheduleTier[]
  items RateScheduleItem[]
  assignments RateBookAssignment[]

  @@index([organizationId])
  @@index([revisionId])
