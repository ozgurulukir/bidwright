  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId     String   @default("")
  name           String   @default("")
  foreman        String   @default("")
  projectManager String   @default("")
  startDate      String?
  shipDate       String?
  poNumber       String   @default("")
  poIssuer       String   @default("")
  status         String   @default("Draft")
  createdAt      DateTime @default(now())

  @@index([projectId])
}

// ── File Nodes ────────────────────────────────────────────────────────────

model FileNode {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId    String?
  name        String
  type        String   @default("file")
  scope       String   @default("project") // "project" | "knowledge"
  fileType    String?
  size        Int?
  documentId  String?
  storagePath String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
