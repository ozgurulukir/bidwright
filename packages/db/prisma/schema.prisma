generator client {
  provider      = "prisma-client-js"
  // Generate to a stable path inside the package rather than the default
  // node_modules/.prisma/client. The dot-prefixed peer doesn't survive
  // pnpm symlink-following during electron-builder packaging, so the
  // packaged Electron app crashes on `require('.prisma/client/default')`.
  // Our explicit output ships naturally with the @bidwright/db workspace
  // dep.
  output        = "../generated/prisma-client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Multi-tenancy Root ────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings                 OrganizationSettings?
  users                    User[]
  sessions                 Session[]
  projects                 Project[]
  catalogs                 Catalog[]
  plugins                  Plugin[]
  entityCategories         EntityCategory[]
  conditionLibrary         ConditionLibraryEntry[]
  knowledgeBooks           KnowledgeBook[]
  knowledgeDocuments       KnowledgeDocument[]
  knowledgeLibraryCabinets KnowledgeLibraryCabinet[]
  datasets                 Dataset[]
  rateSchedules            RateSchedule[]
  rateBookAssignments      RateBookAssignment[]
  customers                Customer[]
  departments              Department[]
  estimatorPersonas        EstimatorPersona[]
  estimateFactorLibrary    EstimateFactorLibraryEntry[]
  assemblies               Assembly[]
  integrations             Integration[]
  resourceCatalogItems     ResourceCatalogItem[]
  laborUnitLibraries       LaborUnitLibrary[]
  costVendors              CostVendor[]
  costVendorProducts       CostVendorProduct[]
  priceObservations        PriceObservation[]
  effectiveCosts           EffectiveCost[]
}

model OrganizationSettings {
  id                 String       @id @default(cuid())
  organizationId     String       @unique
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  general            Json         @default("{}")
  email              Json         @default("{}")
  defaults           Json         @default("{}")
  integrations       Json         @default("{}")
  brand              Json         @default("{}")
  maxUsers           Int          @default(0) // 0 = unlimited
  maxProjects        Int          @default(0) // 0 = unlimited
  maxStorage         Int          @default(0) // MB, 0 = unlimited
  maxKnowledgeBooks  Int          @default(0) // 0 = unlimited
  termsAndConditions String       @default("")
  updatedAt          DateTime     @updatedAt
}

// ── Estimator Personas ───────────────────────────────────────────────────

model EstimatorPersona {
  id                   String       @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                 String
  trade                String       @default("mechanical")
  description          String       @default("")
  systemPrompt         String       @default("")
  knowledgeBookIds     Json         @default("[]")
  knowledgeDocumentIds Json         @default("[]")
  datasetTags          Json         @default("[]")
  packageBuckets       String[]     @default([])
  defaultAssumptions   Json         @default("{}")
  productivityGuidance Json         @default("{}")
  commercialGuidance   Json         @default("{}")
  reviewFocusAreas     String[]     @default([])
  isDefault            Boolean      @default(false)
  enabled              Boolean      @default(true)
  order                Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([organizationId])
}

// ── Users & Auth ──────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  name           String
  role           String       @default("estimator")
  active         Boolean      @default(true)
  passwordHash   String       @default("")
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  activities Activity[]
  sessions   Session[]
  settings   UserSettings?

  @@unique([organizationId, email])
  @@index([organizationId])
}

// Per-user overrides for credentials and preferences. Mirrors the JSON-blob
// pattern used by OrganizationSettings.integrations: keys match the org-level
// integration keys (anthropicKey, openaiKey, geminiKey, openrouterKey, plus
// nested OAuth blocks like anthropicOauth = { accessToken, refreshToken,
// expiresAt }) so the CLI spawn pipeline can shallow-merge user values onto
// org defaults — empty values fall through to the org default.
model UserSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  integrations Json     @default("{}")
  preferences  Json     @default("{}")
  updatedAt    DateTime @updatedAt
}

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  active       Boolean  @default(true)
  // Personal credentials + preferences for the super admin's own
  // session, mirroring UserSettings.integrations / preferences. Used
  // when a super admin manages their own API keys / runtime defaults
  // without first impersonating into an org.
  integrations Json     @default("{}")
  preferences  Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions Session[]
}

model Session {
  id             String        @id @default(cuid())
  token          String        @unique
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  superAdminId   String?
  superAdmin     SuperAdmin?   @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime      @default(now())
  userAgent      String        @default("")
  ipAddress      String        @default("")

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ── Projects ──────────────────────────────────────────────────────────────

model Project {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  clientName        String       @default("")
  location          String       @default("")
  packageName       String       @default("")
  packageUploadedAt String       @default("")
  ingestionStatus   String       @default("queued")
  scope             String       @default("")
  summary           String       @default("")
  // True for "shadow" projects auto-created to hold a single quote (hidden from
  // the projects list and rendered as a flat row in the quotes list).
  // False for explicitly-created container projects that group 2+ quotes.
  isStandalone      Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  sourceDocuments             SourceDocument[]
  quotes                      Quote[]
  fileNodes                   FileNode[]
  aiRuns                      AiRun[]
  citations                   Citation[]
  activities                  Activity[]
  jobs                        Job[]
  packages                    StoredPackage[]
  ingestionJobs               IngestionJob[]
  workspaceState              WorkspaceState?
  pluginExecutions            PluginExecution[]
  pickups                     Pickup[]
  pickupLinks                 PickupLink[]
  dwgEntityLinks              DwgEntityLink[]
  symbolTemplates             SymbolTemplate[]
  modelAssets                 ModelAsset[]
  modelTakeoffLinks           ModelTakeoffLink[]
  modelRevisionDiffs          ModelRevisionDiff[]
  modelFederations            ModelFederation[]
  scheduleTasks               ScheduleTask[]
  scheduleCalendars           ScheduleCalendar[]
  scheduleBaselines           ScheduleBaseline[]
  scheduleResources           ScheduleResource[]
  quoteReviews                QuoteReview[]
  estimateStrategies          EstimateStrategy[]
  estimateCalibrationFeedback EstimateCalibrationFeedback[]
  priceObservations           PriceObservation[]
  effectiveCosts              EffectiveCost[]
  rateBookAssignments         RateBookAssignment[]

  @@index([organizationId])
}

model SourceDocument {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName       String
  fileType       String   @default("")
  documentType   String   @default("reference")
  pageCount      Int      @default(0)
  checksum       String   @default("")
  storagePath    String   @default("")
  extractedText  String   @default("")
  structuredData Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  citations   Citation[]
  modelAssets ModelAsset[]
  priceObservations PriceObservation[]
  symbolTemplates SymbolTemplate[]

  @@index([projectId])
}

// ── Quotes & Revisions ────────────────────────────────────────────────────

model Quote {
  id                         String           @id @default(cuid())
  projectId                  String
  project                    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quoteNumber                String           @default("")
  title                      String           @default("")
  status                     String           @default("draft")
  currentRevisionId          String           @default("")
  customerExistingNew        String           @default("New")
  customerId                 String?
  customer                   Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerString             String           @default("")
  customerContactId          String?
  customerContact            CustomerContact? @relation(fields: [customerContactId], references: [id], onDelete: SetNull)
  customerContactString      String           @default("")
  customerContactEmailString String           @default("")
  departmentId               String?
  department                 Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  userId                     String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  revisions QuoteRevision[]

  @@index([projectId])
  @@index([customerId])
  @@index([departmentId])
}

model QuoteRevision {
  id                       String   @id @default(cuid())
  quoteId                  String
  quote                    Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  revisionNumber           Int      @default(0)
  title                    String   @default("")
  description              String   @default("")
  notes                    String   @default("")
  breakoutStyle            String   @default("grand_total")
  type                     String   @default("Firm")
  scratchpad               String   @default("")
  leadLetter               String   @default("")
  dateEstimatedShip        String?
  dateQuote                String?
  dateDue                  String?
  dateWalkdown             String?
  dateWorkStart            String?
  dateWorkEnd              String?
  shippingMethod           String   @default("")
  shippingTerms            String   @default("")
  freightOnBoard           String   @default("")
  status                   String   @default("Open")
  defaultMarkup            Float    @default(0)
  followUpNote             String   @default("")
  printEmptyNotesColumn    Boolean  @default(false)
  printCategory            String[] @default([])
  printPhaseTotalOnly      Boolean  @default(false)
  grandTotal               Float    @default(0)
  regHours                 Float    @default(0)
  overHours                Float    @default(0)
  doubleHours              Float    @default(0)
  subtotal                 Float    @default(0)
  cost                     Float    @default(0)
  estimatedProfit          Float    @default(0)
  estimatedMargin          Float    @default(0)
  calculatedTotal          Float    @default(0)
  totalHours               Float    @default(0)
  breakoutPackage          Json     @default("[]")
  calculatedCategoryTotals Json     @default("[]")
  pricingLadder            Json     @default("{}")
  summaryLayoutPreset      String   @default("custom")
  pdfPreferences           Json     @default("{}")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  worksheets                  Worksheet[]
  worksheetFolders            WorksheetFolder[]
  phases                      Phase[]
  estimateFactors             EstimateFactor[]
  adjustments                 Adjustment[]
  modifiers                   Modifier[]
  additionalLineItems         AdditionalLineItem[]
  summaryRows                 SummaryRow[]
  conditions                  Condition[]
  reportSections              ReportSection[]
  scheduleTasks               ScheduleTask[]
  scheduleCalendars           ScheduleCalendar[]
  scheduleBaselines           ScheduleBaseline[]
  scheduleResources           ScheduleResource[]
  rateSchedules               RateSchedule[]
  estimateStrategies          EstimateStrategy[]
  estimateCalibrationFeedback EstimateCalibrationFeedback[]
  modelFederations            ModelFederation[]

  @@index([quoteId])
}

// ── Worksheets & Items ────────────────────────────────────────────────────

model WorksheetFolder {
  id         String        @id @default(cuid())
  revisionId String
  revision   QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     WorksheetFolder?  @relation("WorksheetFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   WorksheetFolder[] @relation("WorksheetFolderTree")
  name       String        @default("Folder")
  order      Int           @default(0)

  worksheets Worksheet[]

  @@index([revisionId])
  @@index([parentId])
}

model Worksheet {
  id         String        @id @default(cuid())
  revisionId String
  revision   QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  folderId   String?
  folder     WorksheetFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  name       String        @default("Worksheet 1")
  order      Int           @default(0)

  items             WorksheetItem[]
  assemblyInstances AssemblyInstance[]

  @@index([revisionId])
  @@index([folderId])
}

model WorksheetItem {
  id                 String            @id @default(cuid())
  worksheetId        String
  worksheet          Worksheet         @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  phaseId            String?
  categoryId         String
  entityCategory     EntityCategory    @relation("WorksheetItemEntityCategory", fields: [categoryId], references: [id], onDelete: Restrict)
  category           String            @default("Material")
  entityType         String            @default("Material")
  entityName         String            @default("")
  classification     Json              @default("{}")
  costCode           String?
  vendor             String?
  description        String            @default("")
  quantity           Float             @default(0)
  uom                String            @default("EA")
  cost               Float             @default(0)
  markup             Float             @default(0)
  price              Float             @default(0)
  lineOrder          Int               @default(0)
  rateScheduleItemId String?
  itemId             String? // FK to CatalogItem (for catalog-backed categories)
  tierUnits          Json              @default("{}")
  // Snapshot of where this row's cost/price came from at the time it was
  // last priced. Shape: CostSnapshot in @bidwright/domain. Null/empty for
  // rows that have never been auto-resolved.
  costSnapshot       Json              @default("{}")
  rateResolution     Json              @default("{}")
  sourceNotes        String            @default("")
  costResourceId     String?
  costResource       ResourceCatalogItem? @relation("WorksheetItemCostResource", fields: [costResourceId], references: [id], onDelete: SetNull)
  effectiveCostId    String?
  effectiveCost      EffectiveCost?    @relation("WorksheetItemEffectiveCost", fields: [effectiveCostId], references: [id], onDelete: SetNull)
  laborUnitId        String?
  laborUnit          LaborUnit?        @relation("WorksheetItemLaborUnit", fields: [laborUnitId], references: [id], onDelete: SetNull)
  resourceComposition Json             @default("{}")
  sourceEvidence     Json              @default("{}")
  sourceAssemblyId   String?
  sourceAssembly     Assembly?         @relation("WorksheetItemSourceAssembly", fields: [sourceAssemblyId], references: [id], onDelete: SetNull)
  assemblyInstanceId String?
  assemblyInstance   AssemblyInstance? @relation(fields: [assemblyInstanceId], references: [id], onDelete: SetNull)

  pickupLinks       PickupLink[]
  modelTakeoffLinks ModelTakeoffLink[]
  dwgEntityLinks    DwgEntityLink[]

  @@index([worksheetId])
  @@index([phaseId])
  @@index([categoryId])
  @@index([costCode])
  @@index([costResourceId])
  @@index([effectiveCostId])
  @@index([laborUnitId])
  @@index([sourceAssemblyId])
  @@index([assemblyInstanceId])
}

// ── Phases ────────────────────────────────────────────────────────────────

model Phase {
  id          String        @id @default(cuid())
  revisionId  String
  revision    QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Phase?        @relation("PhaseTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Phase[]       @relation("PhaseTree")
  number      String        @default("")
  name        String        @default("")
  description String        @default("")
  order       Int           @default(0)
  startDate   String?
  endDate     String?
  color       String        @default("")

  @@index([revisionId])
  @@index([parentId])
}

// ── Schedule Tasks ──────────────────────────────────────────────────────

model ScheduleTask {
  id             String            @id @default(cuid())
  projectId      String
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId     String
  revision       QuoteRevision     @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  phaseId        String?
  calendarId     String?
  calendar       ScheduleCalendar? @relation(fields: [calendarId], references: [id], onDelete: SetNull)
  parentTaskId   String?
  parentTask     ScheduleTask?     @relation("ScheduleTaskTree", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks     ScheduleTask[]    @relation("ScheduleTaskTree")
  outlineLevel   Int               @default(0)
  name           String            @default("")
  description    String            @default("")
  taskType       String            @default("task")
  status         String            @default("not_started")
  startDate      String?
  endDate        String?
  duration       Int               @default(0)
  progress       Float             @default(0)
  assignee       String            @default("")
  order          Int               @default(0)
  constraintType String            @default("asap")
  constraintDate String?
  deadlineDate   String?
  actualStart    String?
  actualEnd      String?
  baselineStart  String?
  baselineEnd    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  predecessors ScheduleDependency[]     @relation("successorTask")
  successors   ScheduleDependency[]     @relation("predecessorTask")
  assignments  ScheduleTaskAssignment[]

  @@index([projectId])
  @@index([revisionId])
  @@index([phaseId])
  @@index([calendarId])
  @@index([parentTaskId])
}

model ScheduleDependency {
  id            String       @id @default(cuid())
  predecessorId String
  predecessor   ScheduleTask @relation("predecessorTask", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId   String
  successor     ScheduleTask @relation("successorTask", fields: [successorId], references: [id], onDelete: Cascade)
  type          String       @default("FS")
  lagDays       Int          @default(0)

  @@unique([predecessorId, successorId])
  @@index([predecessorId])
  @@index([successorId])
}

model ScheduleCalendar {
  id                String        @id @default(cuid())
  projectId         String
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId        String
  revision          QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  name              String        @default("")
  description       String        @default("")
  isDefault         Boolean       @default(false)
  workingDays       Json          @default("{}")
  shiftStartMinutes Int           @default(480)
  shiftEndMinutes   Int           @default(1020)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tasks     ScheduleTask[]
  resources ScheduleResource[]

  @@index([projectId])
  @@index([revisionId])
}

model ScheduleBaseline {
  id          String        @id @default(cuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId  String
  revision    QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  name        String        @default("")
  description String        @default("")
  kind        String        @default("custom")
  isPrimary   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items ScheduleBaselineTask[]

  @@index([projectId])
  @@index([revisionId])
}

model ScheduleBaselineTask {
  id         String           @id @default(cuid())
  baselineId String
  baseline   ScheduleBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)
  taskId     String
  taskName   String           @default("")
  phaseId    String?
  startDate  String?
  endDate    String?
  duration   Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([baselineId, taskId])
  @@index([taskId])
}

model ScheduleResource {
  id             String            @id @default(cuid())
  projectId      String
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId     String
  revision       QuoteRevision     @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  calendarId     String?
  calendar       ScheduleCalendar? @relation(fields: [calendarId], references: [id], onDelete: SetNull)
  name           String            @default("")
  role           String            @default("")
  kind           String            @default("labor")
  color          String            @default("")
  defaultUnits   Float             @default(1)
  capacityPerDay Float             @default(1)
  costRate       Float             @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  assignments ScheduleTaskAssignment[]

  @@index([projectId])
  @@index([revisionId])
  @@index([calendarId])
}

model ScheduleTaskAssignment {
  id         String           @id @default(cuid())
  taskId     String
  task       ScheduleTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  resourceId String
  resource   ScheduleResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  units      Float            @default(1)
  role       String           @default("")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([taskId, resourceId])
  @@index([resourceId])
}

// ── Modifiers ─────────────────────────────────────────────────────────────

model Modifier {
  id         String        @id @default(cuid())
  revisionId String
  revision   QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  name       String        @default("")
  type       String        @default("percentage")
  appliesTo  String        @default("All")
  percentage Float?
  amount     Float?
  show       String        @default("Yes")

  @@index([revisionId])
}

// ── Additional Line Items ─────────────────────────────────────────────────

model AdditionalLineItem {
  id          String        @id @default(cuid())
  revisionId  String
  revision    QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  name        String        @default("")
  description String?
  type        String        @default("LineItemAdditional")
  amount      Float         @default(0)

  @@index([revisionId])
}

// ── Summary Rows ──────────────────────────────────────────────────────────

model Adjustment {
  id          String        @id @default(cuid())
  revisionId  String
  revision    QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  order       Int           @default(0)
  kind        String        @default("modifier")
  pricingMode String        @default("modifier")
  name        String        @default("")
  description String        @default("")
  type        String        @default("")
  financialCategory String  @default("other")
  calculationBase   String  @default("selected_scope")
  active      Boolean       @default(true)
  appliesTo   String        @default("All")
  percentage  Float?
  amount      Float?
  show        String        @default("Yes")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([revisionId])
}

model EstimateFactor {
  id          String        @id @default(cuid())
  revisionId  String
  revision    QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  order       Int           @default(0)
  name        String        @default("")
  code        String        @default("")
  description String        @default("")
  category    String        @default("Productivity")
  impact      String        @default("labor_hours")
  value       Float         @default(1)
  active      Boolean       @default(true)
  appliesTo   String        @default("Labour")
  applicationScope String    @default("global")
  scope       Json          @default("{}")
  formulaType String        @default("fixed_multiplier")
  parameters  Json          @default("{}")
  confidence  String        @default("medium")
  sourceType  String        @default("custom")
  sourceId    String?
  sourceRef   Json          @default("{}")
  tags        String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([revisionId])
  @@index([sourceType])
}

model EstimateFactorLibraryEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order          Int          @default(0)
  name           String       @default("")
  code           String       @default("")
  description    String       @default("")
  category       String       @default("Productivity")
  impact         String       @default("labor_hours")
  value          Float        @default(1)
  appliesTo      String       @default("Labour")
  applicationScope String      @default("both")
  scope          Json         @default("{}")
  formulaType    String       @default("fixed_multiplier")
  parameters     Json         @default("{}")
  confidence     String       @default("medium")
  sourceType     String       @default("custom")
  sourceId       String?
  sourceRef      Json         @default("{}")
  tags           String[]     @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([sourceType])
}

model SummaryRow {
  id         String        @id @default(cuid())
  revisionId String
  revision   QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  type    String  @default("heading") // category | phase | adjustment | heading | subtotal | separator
  label   String  @default("")
  order   Int     @default(0)
  visible Boolean @default(true)
  style   String  @default("normal") // normal | bold | indent | highlight

  sourceCategory      String?
  sourcePhase         String?
  sourceCategoryId    String?
  sourceCategoryLabel String?
  sourcePhaseId       String?
  sourceWorksheetId   String?
  sourceWorksheetLabel String?
  sourceClassificationId String?
  sourceClassificationLabel String?
  sourceAdjustmentId  String?

  // Computed (filled by recalculate)
  computedValue  Float @default(0)
  computedCost   Float @default(0)
  computedMargin Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([revisionId])
  @@map("summary_rows")
}

// ── Conditions ────────────────────────────────────────────────────────────

model Condition {
