// ── Pickups (everything in the takeoff Pickups panel) ───────────────────
//
// A Pickup is anything the estimator can promote into a worksheet line
// item: hand-drawn annotations, Auto Count bundles, Smart Count items, and
// any future source that produces a measurable mark on a drawing. The
// concept replaces the older "TakeoffAnnotation" framing — the table /
// model / API / UI all read "Pickup" end-to-end now. Schema shape stays
// identical to TakeoffAnnotation; the `annotationType` column kept its
// name so cached enum values ("linear", "count", "area-rectangle", …)
// keep working without a data migration.

model Pickup {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId     String
  pageNumber     Int
  annotationType String // linear, linear-polyline, linear-drop, count, count-by-distance, area-vertical-wall, area-rectangle, area-triangle, area-ellipse, area-polygon
  label          String   @default("")
  color          String   @default("#3b82f6")
  lineThickness  Float    @default(4)
  visible        Boolean  @default(true)
  groupName      String   @default("")
  points         Json     @default("[]")
  measurement    Json     @default("{}")
  calibration    Json?
  metadata       Json     @default("{}")
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pickupLinks PickupLink[]

  @@index([projectId])
  @@index([documentId])
}

// ── Pickup Links (M:N junction: Pickup ↔ WorksheetItem) ──────────────────

model PickupLink {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pickupId        String
  pickup          Pickup        @relation(fields: [pickupId], references: [id], onDelete: Cascade)
  worksheetItemId String
  worksheetItem   WorksheetItem @relation(fields: [worksheetItemId], references: [id], onDelete: Cascade)
  quantityField   String        @default("value") // "value" | "area" | "volume" | "count"
  multiplier      Float         @default(1.0) // 1.1 = 10% waste
  derivedQuantity Float         @default(0) // cached: measurement[quantityField] * multiplier
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([pickupId, worksheetItemId])
  @@index([pickupId])
  @@index([worksheetItemId])
  @@index([projectId])
}

// ── DWG Entity Links ──────────────────────────────────────────────────────
// Direct link from a CAD entity (DXF/DWG) to a worksheet line item, without
// requiring an intermediate annotation. Useful for tagging native CAD
// geometry (a wall, a duct, a fixture) to its estimate row.

model DwgEntityLink {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId      String        // takeoff document id (file-<fileNodeId> or doc-<sourceDocumentId>)
  entityId        String        // CAD entity id from the DXF/DWG parser
  entityType      String        @default("") // "line" | "circle" | "polyline" | etc.
  layer           String        @default("")
  worksheetItemId String
  worksheetItem   WorksheetItem @relation(fields: [worksheetItemId], references: [id], onDelete: Cascade)
  quantity        Float         @default(0) // user-supplied (DWG entities lack intrinsic measurement)
  multiplier      Float         @default(1.0)
  derivedQuantity Float         @default(0) // cached: quantity * multiplier
  selection       Json          @default("{}") // entity context for display (geometry summary, layer, color)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([documentId, entityId, worksheetItemId])
  @@index([projectId])
  @@index([documentId])
  @@index([entityId])
  @@index([worksheetItemId])
}

// ── Symbol Library (Few-Shot from Legend) ────────────────────────────────
//
// A SymbolTemplate is a cropped image of one symbol from a drawing's legend,
// stored per-project. After capturing the legend the user can run
// "Count Project Library" on any drawing to detect every saved symbol at
// once via OpenCV template matching.
//
// The PNG bytes live on disk at
//   apiDataRoot/projects/<projectId>/symbol-templates/<id>.png
// and only the relative path is stored in storagePath — matching the
// SourceDocument.storagePath convention.

model SymbolTemplate {
  id               String          @id @default(cuid())
  projectId        String
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // The short token from the legend ("A1", "GFI", "$"). May be empty when
  // the legend cell only had a glyph and no readable text.
  symbol           String          @default("")
  // Human-readable label ("Standard duplex receptacle").
  label            String          @default("")
  // PNG storage path, relative to apiDataRoot. The on-disk file is the
  // authoritative template image used by the OpenCV matcher.
  storagePath      String
  // Template image dimensions in pixels at the captured DPI. Used to size
  // result rectangles back to the original symbol footprint.
  width            Int             @default(0)
  height           Int             @default(0)
  dpi              Int             @default(150)
  // Provenance: where in the legend the template was cropped from. SetNull
  // so the template survives when the source document is deleted (the PNG
  // is independent of the source PDF).
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sourcePage       Int             @default(1)
  // Source bbox in render-image-coord space:
  // { x, y, width, height, imageWidth, imageHeight }
  sourceBbox       Json            @default("{}")
  // Per-template defaults. Caller can override at run time. Empirically
  // validated optimum is threshold=0.75, crossScale=false for same-package
  // matching; crossScale=true for cross-document searches.
  threshold        Float           @default(0.75)
  crossScale       Boolean         @default(false)
  // Whether to include this template in "Run Project Library" batch runs.
  // Lets the user mute noisy templates without deleting them.
  enabled          Boolean         @default(true)
  // Free-form metadata: legend extraction confidence, last-run statistics,
  // user notes. Shape: SymbolTemplateMetadata in @bidwright/domain.
  metadata         Json            @default("{}")
  createdBy        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([projectId])
  @@index([sourceDocumentId])
}

// ── AI Runs ───────────────────────────────────────────────────────────────

// ── Model Assets & 3D Takeoff ─────────────────────────────────────────────

model ModelAsset {
  id               String          @id @default(cuid())
  projectId        String
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  fileNodeId       String?
  fileNode         FileNode?       @relation(fields: [fileNodeId], references: [id], onDelete: SetNull)
  fileName         String
  fileType         String          @default("")
  format           String          @default("")
  status           String          @default("indexed")
  units            String          @default("")
  checksum         String          @default("")
  storagePath      String          @default("")
  manifest         Json            @default("{}")
  bom              Json            @default("[]")
  elementStats     Json            @default("{}")
  metadata         Json            @default("{}")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  elements          ModelElement[]
  quantities        ModelQuantity[]
  boms              ModelBom[]
  issues            ModelIssue[]
  takeoffLinks      ModelTakeoffLink[]
  revisionDiffsBase ModelRevisionDiff[] @relation("ModelRevisionBase")
  revisionDiffsHead ModelRevisionDiff[] @relation("ModelRevisionHead")
  federationMemberships ModelFederationMember[]

  @@unique([projectId, sourceDocumentId])
  @@unique([projectId, fileNodeId])
  @@index([projectId])
  @@index([sourceDocumentId])
  @@index([fileNodeId])
}

model ModelElement {
  id           String         @id @default(cuid())
  modelId      String
  model        ModelAsset     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  externalId   String         @default("")
  parentId     String?
  parent       ModelElement?  @relation("ModelElementTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     ModelElement[] @relation("ModelElementTree")
  name         String         @default("")
  elementClass String         @default("")
  elementType  String         @default("")
  system       String         @default("")
  level        String         @default("")
  material     String         @default("")
  bbox         Json           @default("{}")
  geometryRef  String         @default("")
  /// Construction classification keyed by standard. Mirrors the WorksheetItem
  /// shape (see classification-utils.ts) so codes propagate cleanly into the
  /// existing summary rollups (by_uniformat_division, by_masterformat_division,
  /// etc). Keys: masterformat | uniformat | omniclass | uniclass | din276 | nrm | icms.
  classification Json         @default("{}")
  /// Level of Development. Sourced from IFC Pset_VerificationStatus / Pset_LOD
  /// when present; manual override via UI takes precedence. Values: "100" | "200"
  /// | "300" | "350" | "400" | "500" | "" (untagged).
  lod          String         @default("")
  /// Source of the LOD tag: "manual" | "pset" | "" (untagged). Lets the UI show
  /// where the value came from and prevents pset-imports from clobbering manual
  /// overrides on subsequent re-ingest.
  lodSource    String         @default("")
  /// Catch-all for everything not promoted to a typed column (raw IFC Psets,
  /// non-estimating Revit parameters, etc.). Always present; queries should
  /// prefer typed columns where available.
  properties   Json           @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  quantities   ModelQuantity[]
  takeoffLinks ModelTakeoffLink[]
  issues       ModelIssue[]

  @@index([modelId])
  @@index([modelId, externalId])
  @@index([elementClass])
  @@index([lod])
}

model ModelQuantity {
  id           String        @id @default(cuid())
  modelId      String
  model        ModelAsset    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  elementId    String?
  element      ModelElement? @relation(fields: [elementId], references: [id], onDelete: Cascade)
  quantityType String
  value        Float         @default(0)
  unit         String        @default("")
  method       String        @default("computed")
  confidence   Float         @default(1)
  metadata     Json          @default("{}")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  takeoffLinks ModelTakeoffLink[]

  @@index([modelId])
  @@index([elementId])
  @@index([quantityType])
}

model ModelBom {
  id        String     @id @default(cuid())
  modelId   String
  model     ModelAsset @relation(fields: [modelId], references: [id], onDelete: Cascade)
  grouping  String     @default("native")
  filters   Json       @default("{}")
  rows      Json       @default("[]")
  createdBy String     @default("")
  createdAt DateTime   @default(now())

  @@index([modelId])
}

model ModelTakeoffLink {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  modelId         String
  model           ModelAsset     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  modelElementId  String?
  modelElement    ModelElement?  @relation(fields: [modelElementId], references: [id], onDelete: SetNull)
  modelQuantityId String?
  modelQuantity   ModelQuantity? @relation(fields: [modelQuantityId], references: [id], onDelete: SetNull)
  worksheetItemId String
  worksheetItem   WorksheetItem  @relation(fields: [worksheetItemId], references: [id], onDelete: Cascade)
  quantityField   String         @default("quantity")
  multiplier      Float          @default(1.0)
  derivedQuantity Float          @default(0)
  selection       Json           @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([projectId])
  @@index([modelId])
  @@index([modelElementId])
  @@index([modelQuantityId])
  @@index([worksheetItemId])
}

/// A coordinated grouping of one or more ModelAssets that drive a single
/// estimate. This is how multi-discipline BIM works in the real world:
/// architectural + structural + MEP authored separately, federated for takeoff.
/// Standalone lifecycle — optionally associated with a quote revision for
/// scenario branching, but a federation can also exist project-wide as the
/// "current" coordinated model.
model ModelFederation {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String         @default("")
  /// Optional link to a specific quote revision. When set, the federation
  /// drives that revision's takeoff/re-takeoff. When null, the federation is
  /// "loose" — usable as a working draft or a project-wide reference.
  revisionId  String?
  revision    QuoteRevision? @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  /// "active" | "draft" | "archived" — soft state separate from revision status.
  status      String         @default("active")
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  members     ModelFederationMember[]

  @@index([projectId])
  @@index([revisionId])
}

/// Membership of a ModelAsset in a ModelFederation. One ModelAsset can belong
/// to many federations (e.g. the same architectural model federated into
/// different scenarios), and a federation has many members.
model ModelFederationMember {
  id           String          @id @default(cuid())
  federationId String
  federation   ModelFederation @relation(fields: [federationId], references: [id], onDelete: Cascade)
  modelId      String
  model        ModelAsset      @relation(fields: [modelId], references: [id], onDelete: Cascade)
  /// Discipline tag for the member: "architecture" | "structure" | "mep" |
  /// "civil" | "landscape" | "fp" | "other". Used for grouping in the
  /// federation switcher UI; not enforced as enum because non-standard
  /// disciplines come up.
  discipline   String          @default("other")
  /// "primary" | "reference" | "clash". Primary members contribute quantities
  /// to the takeoff; reference members are visible in the viewer but don't
  /// roll up; clash members are used for coordination only.
  role         String          @default("primary")
  /// Display order within the federation.
  position     Int             @default(0)
  metadata     Json            @default("{}")
  createdAt    DateTime        @default(now())

  @@unique([federationId, modelId])
  @@index([federationId])
  @@index([modelId])
}

model ModelIssue {
  id        String        @id @default(cuid())
  modelId   String
  model     ModelAsset    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  elementId String?
  element   ModelElement? @relation(fields: [elementId], references: [id], onDelete: SetNull)
  severity  String        @default("info")
  code      String        @default("")
  message   String
  metadata  Json          @default("{}")
  resolved  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([modelId])
  @@index([elementId])
  @@index([severity])
}

model ModelRevisionDiff {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  baseModelId String
  baseModel   ModelAsset @relation("ModelRevisionBase", fields: [baseModelId], references: [id], onDelete: Cascade)
  headModelId String
  headModel   ModelAsset @relation("ModelRevisionHead", fields: [headModelId], references: [id], onDelete: Cascade)
  summary     Json       @default("{}")
  rows        Json       @default("[]")
  createdAt   DateTime   @default(now())

  @@index([projectId])
  @@index([baseModelId])
  @@index([headModelId])
}

model AiRun {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId    String?
  kind          String
  status        String   @default("queued")
  model         String   @default("")
  promptVersion String   @default("")
  input         Json     @default("{}")
  output        Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

// ── Quote Reviews ─────────────────────────────────────────────────────────

model QuoteReview {
  id                          String                        @id @default(cuid())
  projectId                   String
  project                     Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId                  String
  aiRunId                     String?
  status                      String                        @default("running") // running | completed | failed
  summary                     Json                          @default("{}")
  coverage                    Json                          @default("[]")
  findings                    Json                          @default("[]")
  competitiveness             Json                          @default("{}")
  recommendations             Json                          @default("[]")
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  estimateCalibrationFeedback EstimateCalibrationFeedback[]

  @@index([projectId])
  @@index([revisionId])
}

// ── Estimate Strategy & Calibration ────────────────────────────────────────

model EstimateStrategy {
  id                   String        @id @default(cuid())
  projectId            String
  project              Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId           String        @unique
  revision             QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  aiRunId              String?
  personaId            String?
  status               String        @default("draft") // draft | in_progress | ready_for_review | complete
  currentStage         String        @default("scope") // scope | execution | packaging | benchmark | reconcile | complete
  scopeGraph           Json          @default("{}")
  executionPlan        Json          @default("{}")
  assumptions          Json          @default("[]")
  packagePlan          Json          @default("[]")
  benchmarkProfile     Json          @default("{}")
  benchmarkComparables Json          @default("[]")
  adjustmentPlan       Json          @default("[]")
  reconcileReport      Json          @default("{}")
  confidenceSummary    Json          @default("{}")
  summary              Json          @default("{}")
  reviewRequired       Boolean       @default(true)
  reviewCompleted      Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  feedback EstimateCalibrationFeedback[]

  @@index([projectId])
  @@index([status])
}

model EstimateCalibrationFeedback {
  id            String            @id @default(cuid())
  projectId     String
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId    String
  revision      QuoteRevision     @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  strategyId    String?
  strategy      EstimateStrategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  quoteReviewId String?
  quoteReview   QuoteReview?      @relation(fields: [quoteReviewId], references: [id], onDelete: SetNull)
  source        String            @default("manual")
  feedbackType  String            @default("comparison")
  sourceLabel   String            @default("")
  aiSnapshot    Json              @default("{}")
  humanSnapshot Json              @default("{}")
  deltaSummary  Json              @default("{}")
  corrections   Json              @default("[]")
  lessons       Json              @default("[]")
  notes         String            @default("")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([projectId])
  @@index([revisionId])
  @@index([strategyId])
}

// ── Citations ─────────────────────────────────────────────────────────────

model Citation {
  id               String          @id @default(cuid())
  projectId        String
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  aiRunId          String?
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  resourceType     String          @default("source_document")
  resourceKey      String          @default("")
  pageStart        Int?
  pageEnd          Int?
  excerpt          String          @default("")
  confidence       Float           @default(0)

  @@index([projectId])
}

// ── Activities ────────────────────────────────────────────────────────────

model Activity {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId String?
  type       String
  data       Json     @default("{}")
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([projectId])
}

// ── Catalogs ──────────────────────────────────────────────────────────────

model Catalog {
  id                String        @id @default(cuid())
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  kind              String
  scope             String        @default("global")
  projectId         String?
  description       String        @default("")
  source            String        @default("manual")
  sourceDescription String        @default("")
  isTemplate        Boolean       @default(false)
  sourceTemplateId  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  items CatalogItem[]

  @@index([organizationId])
  @@index([isTemplate])
}

model CatalogItem {
  id        String   @id @default(cuid())
  catalogId String
  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  code      String   @default("")
  name      String   @default("")
  unit      String   @default("")
  unitCost  Float    @default(0)
  unitPrice Float    @default(0)
  metadata  Json     @default("{}")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assemblyComponents   AssemblyComponent[]
  rateScheduleItems    RateScheduleItem[]
  resourceCatalogItems ResourceCatalogItem[]
  laborUnits           LaborUnit[]

  @@index([catalogId])
}

// ── Cost Intelligence ───────────────────────────────────────────────────

model CostVendor {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String       @default("")
  aliases        String[]     @default([])
  website        String       @default("")
  contactInfo    Json         @default("{}")
  metadata       Json         @default("{}")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  products          CostVendorProduct[]
  priceObservations PriceObservation[]
  effectiveCosts    EffectiveCost[]

  @@unique([organizationId, normalizedName])
  @@index([organizationId])
  @@index([organizationId, name])
}

model CostVendorProduct {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendorId       String
  vendor         CostVendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  resourceId     String?
  resource       ResourceCatalogItem? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  sku            String               @default("")
  name           String
  normalizedName String               @default("")
  description    String               @default("")
  defaultUom     String               @default("EA")
  metadata       Json                 @default("{}")
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  priceObservations PriceObservation[]
  effectiveCosts    EffectiveCost[]

  @@unique([vendorId, sku, normalizedName, defaultUom])
  @@index([organizationId])
  @@index([vendorId])
  @@index([resourceId])
  @@index([organizationId, sku])
}

model ResourceCatalogItem {
  id                     String        @id @default(cuid())
  organizationId         String
  organization           Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  catalogItemId          String?
  catalogItem            CatalogItem?   @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  resourceType           String        @default("material")
  category               String        @default("")
  code                   String        @default("")
  name                   String
  normalizedName         String        @default("")
  description            String        @default("")
  manufacturer           String        @default("")
  manufacturerPartNumber String        @default("")
  defaultUom             String        @default("EA")
  aliases                String[]      @default([])
  tags                   String[]      @default([])
  metadata               Json          @default("{}")
  active                 Boolean       @default(true)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  priceObservations PriceObservation[]
  effectiveCosts    EffectiveCost[]
  vendorProducts    CostVendorProduct[]
  assemblyComponents AssemblyComponent[]
  worksheetItems    WorksheetItem[] @relation("WorksheetItemCostResource")
  rateScheduleItems RateScheduleItem[]

  @@index([organizationId])
  @@index([organizationId, resourceType])
  @@index([organizationId, code])
  @@index([catalogItemId])
}

model PriceObservation {
  id               String               @id @default(cuid())
  organizationId   String
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resourceId       String?
  resource         ResourceCatalogItem? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  vendorId         String?
  vendor           CostVendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorProductId  String?
  vendorProduct    CostVendorProduct?   @relation(fields: [vendorProductId], references: [id], onDelete: SetNull)
  projectId        String?
  project          Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sourceDocumentId String?
  sourceDocument   SourceDocument?      @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  vendorName       String               @default("")
  vendorSku        String               @default("")
  documentType     String               @default("manual")
  observedAt       DateTime             @default(now())
  effectiveDate    String?
  quantity         Float                @default(1)
  observedUom      String               @default("EA")
  unitCost         Float                @default(0)
  unitPrice        Float?
  currency         String               @default("USD")
  freight          Float                @default(0)
  tax              Float                @default(0)
  discount         Float                @default(0)
  confidence       Float                @default(0)
  fingerprint      String               @default("")
  sourceRef        Json                 @default("{}")
  rawText          String               @default("")
  metadata         Json                 @default("{}")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  effectiveCostCitations EffectiveCost[] @relation("EffectiveCostSourceObservation")

  @@index([organizationId])
  @@index([resourceId, observedAt])
  @@index([vendorId])
  @@index([vendorProductId])
  @@index([projectId])
  @@index([sourceDocumentId])
  @@index([organizationId, vendorName])
  @@index([organizationId, fingerprint])
}

model EffectiveCost {
  id                  String              @id @default(cuid())
  organizationId      String
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resourceId          String?
  resource            ResourceCatalogItem? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  vendorId            String?
  vendor              CostVendor?         @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorProductId     String?
  vendorProduct       CostVendorProduct?  @relation(fields: [vendorProductId], references: [id], onDelete: SetNull)
  projectId           String?
  project             Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  vendorName          String              @default("")
  region              String              @default("")
  uom                 String              @default("EA")
  unitCost            Float               @default(0)
  unitPrice           Float?
  currency            String              @default("USD")
  effectiveDate       String?
  expiresAt           String?
  sourceObservationId String?
  sourceObservation   PriceObservation?   @relation("EffectiveCostSourceObservation", fields: [sourceObservationId], references: [id], onDelete: SetNull)
  method              String              @default("latest_observation")
  sampleSize          Int                 @default(0)
  confidence          Float               @default(0)
  metadata            Json                @default("{}")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  assemblyComponents AssemblyComponent[]
  worksheetItems      WorksheetItem[] @relation("WorksheetItemEffectiveCost")

  @@index([organizationId])
  @@index([resourceId])
  @@index([vendorId])
  @@index([vendorProductId])
  @@index([projectId])
  @@index([sourceObservationId])
  @@index([organizationId, resourceId, uom, currency])
}

// ── Assemblies ────────────────────────────────────────────────────────────

model Assembly {
  id               String        @id @default(cuid())
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  code             String        @default("")
  description      String        @default("")
  category         String        @default("")
  unit             String        @default("EA")
  isTemplate       Boolean       @default(false)
  sourceTemplateId String?
  metadata         Json          @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  parameters         AssemblyParameter[]
  components         AssemblyComponent[]
  parentReferences   AssemblyComponent[] @relation("AssemblyComponentSubAssembly")
  worksheetSnapshots WorksheetItem[]     @relation("WorksheetItemSourceAssembly")
  assemblyInstances  AssemblyInstance[]

  @@index([organizationId])
  @@index([isTemplate])
}

model AssemblyParameter {
  id           String   @id @default(cuid())
  assemblyId   String
  assembly     Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  key          String
  label        String   @default("")
  description  String   @default("")
  paramType    String   @default("number")
  defaultValue String   @default("0")
  unit         String   @default("")
  sortOrder    Int      @default(0)

  @@unique([assemblyId, key])
  @@index([assemblyId])
}

model AssemblyInstance {
  id              String    @id @default(cuid())
  worksheetId     String
  worksheet       Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  assemblyId      String?
  assembly        Assembly? @relation(fields: [assemblyId], references: [id], onDelete: SetNull)
  phaseId         String?
  quantity        Float     @default(1)
  parameterValues Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  worksheetItems WorksheetItem[]

  @@index([worksheetId])
  @@index([assemblyId])
}

model AssemblyComponent {
  id                 String            @id @default(cuid())
  assemblyId         String
  assembly           Assembly          @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  componentType      String
  catalogItemId      String?
  catalogItem        CatalogItem?      @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  rateScheduleItemId String?
  rateScheduleItem   RateScheduleItem? @relation(fields: [rateScheduleItemId], references: [id], onDelete: SetNull)
  laborUnitId        String?
  laborUnit          LaborUnit?        @relation(fields: [laborUnitId], references: [id], onDelete: SetNull)
  costResourceId     String?
  costResource       ResourceCatalogItem? @relation(fields: [costResourceId], references: [id], onDelete: SetNull)
  effectiveCostId    String?
  effectiveCost      EffectiveCost?    @relation(fields: [effectiveCostId], references: [id], onDelete: SetNull)
  subAssemblyId      String?
  subAssembly        Assembly?         @relation("AssemblyComponentSubAssembly", fields: [subAssemblyId], references: [id], onDelete: Restrict)
  quantityExpr       String            @default("1")
  description        String            @default("")
  category           String            @default("")
  uomOverride        String?
  costOverride       Float?
  markupOverride     Float?
  parameterBindings  Json              @default("{}")
  notes              String            @default("")
  sortOrder          Int               @default(0)

  @@index([assemblyId])
  @@index([catalogItemId])
  @@index([rateScheduleItemId])
  @@index([laborUnitId])
  @@index([costResourceId])
  @@index([effectiveCostId])
  @@index([subAssemblyId])
}

// ── Condition Library (global per-org) ────────────────────────────────────

model ConditionLibraryEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String
  value          String

  @@index([organizationId])
}

// ── Plugins ───────────────────────────────────────────────────────────────

model Plugin {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                String
  slug                String
  icon                String?
  category            String       @default("general")
  description         String       @default("")
  llmDescription      String?
  version             String       @default("1.0.0")
  author              String?
  enabled             Boolean      @default(true)
  config              Json         @default("{}")
  configSchema        Json?
  toolDefinitions     Json         @default("[]")
  defaultOutputType   String?
  supportedCategories String[]     @default([])
  tags                String[]     @default([])
  documentation       String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  executions PluginExecution[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model PluginExecution {
  id                 String   @id @default(cuid())
  pluginId           String
  plugin             Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  toolId             String
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId         String
  worksheetId        String?
  input              Json     @default("{}")
  formState          Json?
  output             Json     @default("{}")
  appliedLineItemIds String[] @default([])
  status             String   @default("pending")
  error              String?
  executedBy         String?
  agentSessionId     String?
  createdAt          DateTime @default(now())

  @@index([projectId])
  @@index([pluginId])
}

model LineItemSearchDocument {
  id             String   @id
  organizationId String
  projectId      String?
  sourceType     String
  sourceId       String
  actionType     String   @default("select")
  category       String   @default("")
  entityType     String   @default("")
  title          String
  subtitle       String   @default("")
  code           String   @default("")
  vendor         String   @default("")
  uom            String   @default("EA")
  unitCost       Float?
  unitPrice      Float?
  searchText     String   @default("")
  searchVector   Unsupported("tsvector") @default(dbgenerated("''::tsvector"))
  payload        Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, projectId])
  @@index([organizationId, sourceType])
  @@index([organizationId, category])
  @@index([organizationId, entityType])
}

// ── Knowledge ─────────────────────────────────────────────────────────────

model KnowledgeBook {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cabinetId      String?
  cabinet        KnowledgeLibraryCabinet? @relation("KnowledgeBookCabinet", fields: [cabinetId], references: [id], onDelete: SetNull)
  name           String
  description    String                   @default("")
  category       String                   @default("general")
  scope          String                   @default("global")
  projectId      String?
  pageCount      Int                      @default(0)
  chunkCount     Int                      @default(0)
  status         String                   @default("uploading")
  sourceFileName String                   @default("")
  sourceFileSize Int                      @default(0)
  storagePath    String?
  metadata       Json                     @default("{}")
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  chunks KnowledgeChunk[]

  @@index([organizationId])
  @@index([cabinetId])
}

model KnowledgeChunk {
  id           String        @id @default(cuid())
  bookId       String
  book         KnowledgeBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  pageNumber   Int?
  sectionTitle String        @default("")
  text         String        @default("")
  tokenCount   Int           @default(0)
  order        Int           @default(0)
  metadata     Json          @default("{}")

  @@index([bookId])
}

model KnowledgeDocument {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cabinetId      String?
  cabinet        KnowledgeLibraryCabinet? @relation("KnowledgeDocumentCabinet", fields: [cabinetId], references: [id], onDelete: SetNull)
  title          String
  description    String                   @default("")
  category       String                   @default("general")
  scope          String                   @default("global")
  projectId      String?
  tags           String[]                 @default([])
  pageCount      Int                      @default(0)
  chunkCount     Int                      @default(0)
  status         String                   @default("draft")
  metadata       Json                     @default("{}")
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  pages  KnowledgeDocumentPage[]
  chunks KnowledgeDocumentChunk[]

  @@index([organizationId])
  @@index([cabinetId])
  @@index([scope])
  @@index([projectId])
}

model KnowledgeDocumentPage {
  id              String            @id @default(cuid())
  documentId      String
  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  title           String
  slug            String            @default("")
  order           Int               @default(0)
  contentJson     Json              @default("{}")
  contentMarkdown String            @default("")
  plainText       String            @default("")
  metadata        Json              @default("{}")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  chunks KnowledgeDocumentChunk[]

  @@index([documentId])
  @@index([documentId, order])
}

model KnowledgeDocumentChunk {
  id           String                 @id @default(cuid())
  documentId   String
  document     KnowledgeDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  pageId       String?
  page         KnowledgeDocumentPage? @relation(fields: [pageId], references: [id], onDelete: Cascade)
  sectionTitle String                 @default("")
  text         String                 @default("")
  tokenCount   Int                    @default(0)
  order        Int                    @default(0)
  metadata     Json                   @default("{}")

  @@index([documentId])
  @@index([pageId])
}

model KnowledgeLibraryCabinet {
  id             String                    @id @default(cuid())
  organizationId String
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         KnowledgeLibraryCabinet?  @relation("KnowledgeLibraryCabinetTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       KnowledgeLibraryCabinet[] @relation("KnowledgeLibraryCabinetTree")
  itemType       String
  name           String
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  books     KnowledgeBook[]     @relation("KnowledgeBookCabinet")
  documents KnowledgeDocument[] @relation("KnowledgeDocumentCabinet")
  datasets  Dataset[]           @relation("DatasetCabinet")
  laborUnitLibraries LaborUnitLibrary[] @relation("LaborUnitLibraryCabinet")

  @@index([organizationId])
  @@index([parentId])
  @@index([organizationId, itemType])
}

// ── Datasets ──────────────────────────────────────────────────────────────

model Dataset {
  id                String                   @id @default(cuid())
  organizationId    String?
  organization      Organization?            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cabinetId         String?
  cabinet           KnowledgeLibraryCabinet? @relation("DatasetCabinet", fields: [cabinetId], references: [id], onDelete: SetNull)
  name              String
  description       String                   @default("")
  category          String                   @default("custom")
  scope             String                   @default("global")
  projectId         String?
  columns           Json                     @default("[]")
  rowCount          Int                      @default(0)
  source            String                   @default("manual")
  sourceDescription String                   @default("")
  sourceBookId      String? // Link back to KnowledgeBook this was extracted from
  sourcePages       String                   @default("") // Page range(s) e.g. "85-87, 100"
  tags              String[]                 @default([]) // Rich tags for search: ["pipe", "flange", "man-hours", "carbon-steel"]
  isTemplate        Boolean                  @default(false)
  sourceTemplateId  String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  rows DatasetRow[]

  @@index([organizationId])
  @@index([isTemplate])
  @@index([cabinetId])
}

model DatasetRow {
  id        String   @id @default(cuid())
  datasetId String
  dataset   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  data      Json     @default("{}")
  order     Int      @default(0)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([datasetId])
}

// ── Labor Units ───────────────────────────────────────────────────────────

model LaborUnitLibrary {
  id                String                   @id @default(cuid())
  organizationId    String?
  organization      Organization?            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cabinetId         String?
  cabinet           KnowledgeLibraryCabinet? @relation("LaborUnitLibraryCabinet", fields: [cabinetId], references: [id], onDelete: SetNull)
  name              String
  description       String                   @default("")
  provider          String                   @default("")
  discipline        String                   @default("")
  source            String                   @default("manual")
  sourceDescription String                   @default("")
  sourceDatasetId   String?
  tags              String[]                 @default([])
  isTemplate        Boolean                  @default(false)
  sourceTemplateId  String?
  metadata          Json                     @default("{}")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  units LaborUnit[]

  @@index([organizationId])
  @@index([cabinetId])
  @@index([isTemplate])
  @@index([provider])
}

model LaborUnit {
  id                 String           @id @default(cuid())
  libraryId          String
  library            LaborUnitLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  catalogItemId      String?
  catalogItem        CatalogItem?     @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  code               String           @default("")
  name               String
  description        String           @default("")
  discipline         String           @default("")
  category           String           @default("")
  className          String           @default("")
  subClassName       String           @default("")
  outputUom          String           @default("EA")
  hoursNormal        Float            @default(0)
  entityCategoryType String           @default("Labour")
  tags               String[]         @default([])
  sourceRef          Json             @default("{}")
  metadata           Json             @default("{}")
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  assemblyComponents AssemblyComponent[]
  worksheetItems      WorksheetItem[] @relation("WorksheetItemLaborUnit")

  @@index([libraryId])
  @@index([catalogItemId])
  @@index([category])
  @@index([className])
  @@index([subClassName])
  @@index([entityCategoryType])
}

// ── Entity Categories ─────────────────────────────────────────────────────

model EntityCategory {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  entityType      String
  shortform       String       @default("")
  defaultUom      String       @default("EA")
  validUoms       String[]     @default([])
  editableFields  Json         @default("{}")
  unitLabels      Json         @default("{}") @map("laborHourLabels")
  calculationType String       @default("manual")
  calcFormula     String       @default("") // custom formula expression for "formula" calc type
  itemSource      String       @default("freeform") // "rate_schedule" | "catalog" | "freeform"
  catalogId       String? // When itemSource="catalog", which catalog backs this category
  // Analytics roll-up bucket. Drives the labour/material/equipment breakout
  // style, the per-bucket benchmark output, and allowance detection — instead
  // of code branching on hardcoded category names. Free string; common values:
  // "labour" | "material" | "equipment" | "subcontractor" | "allowance".
  analyticsBucket String?
  color           String       @default("#6b7280")
  order           Int          @default(0)
  isBuiltIn       Boolean      @default(false)
  enabled         Boolean      @default(true)

  worksheetItems  WorksheetItem[] @relation("WorksheetItemEntityCategory")

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ── Package & Ingestion Tracking ──────────────────────────────────────────

model StoredPackage {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  packageName      String    @default("")
  originalFileName String    @default("")
  sourceKind       String    @default("project")
  storagePath      String    @default("")
  reportPath       String?
  chunksPath       String?
  checksum         String    @default("")
  totalBytes       Int       @default(0)
  status           String    @default("uploaded")
  documentCount    Int       @default(0)
  chunkCount       Int       @default(0)
  documentIds      String[]  @default([])
  unknownFiles     String[]  @default([])
  uploadedAt       DateTime  @default(now())
  ingestedAt       DateTime?
  updatedAt        DateTime  @updatedAt
  error            String?

  @@index([projectId])
}

model IngestionJob {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  packageId   String?
  kind        String
  status      String    @default("queued")
  progress    Int       @default(0)
  input       Json      @default("{}")
  output      Json?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  storagePath String?

  @@index([projectId])
}

// ── Workspace State (UI preferences per project) ──────────────────────────

model WorkspaceState {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  state     Json     @default("{}")
  updatedAt DateTime @updatedAt
}

// ── Customers ─────────────────────────────────────────────────────────────

model Customer {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  shortName         String       @default("")
  phone             String       @default("")
  email             String       @default("")
  website           String       @default("")
  addressStreet     String       @default("")
  addressCity       String       @default("")
  addressProvince   String       @default("")
  addressPostalCode String       @default("")
  addressCountry    String       @default("")
  notes             String       @default("")
  active            Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  contacts CustomerContact[]
  quotes   Quote[]
  rateBookAssignments RateBookAssignment[]

  @@index([organizationId])
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  title      String   @default("")
  phone      String   @default("")
  email      String   @default("")
  isPrimary  Boolean  @default(false)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  quotes Quote[]

  @@index([customerId])
}

// ── Departments ───────────────────────────────────────────────────────────

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String       @default("")
  description    String       @default("")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  quotes Quote[]

  @@index([organizationId])
}


// ── Integrations ──────────────────────────────────────────────────────────
//
// Manifest-driven framework for connecting external systems (legacy source, Procore,
// QuickBooks, Slack, custom REST, ...). Distinct from Plugin — Plugins produce
// estimate artifacts, Integrations talk to outside systems. Tools surfaced to
// the agent and MCP under namespace `integration.{slug}.{action}`.

model Integration {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manifestId        String       // e.g. "legacy-source", "procore", "generic-rest"
  manifestVersion   String       // semver of installed manifest
  manifestSource    String       @default("builtin") // builtin | community | custom
  manifestSnapshot  Json         // frozen manifest at install time (audit + offline)
  slug              String       // unique per-org instance slug, often equals manifestId
  displayName       String
  description       String       @default("")
  icon              String?
  category          String       @default("other") // erp | crm | accounting | construction | comms | storage | identity | other
  enabled           Boolean      @default(true)
  status            String       @default("needs_auth") // needs_auth | connected | error | paused | disabled
  lastError         String?
  lastTestedAt      DateTime?
  lastConnectedAt   DateTime?
  config            Json         @default("{}") // non-secret config (account ids, base urls, feature flags)
  scopes            String[]     @default([])   // OAuth scopes granted (subset of manifest.connection.scopes)
  exposeToAgent     Boolean      @default(true) // surface actions in agent tool registry
  exposeToMcp       Boolean      @default(true) // surface actions over MCP
  createdBy         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  credentials  IntegrationCredential[]
  syncStates   IntegrationSyncState[]
  events       IntegrationEvent[]
  runs         IntegrationRun[]
  externalRecords ExternalRecord[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([manifestId])
  @@index([status])
}

model IntegrationCredential {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  // kind = "api_key" | "oauth_access_token" | "oauth_refresh_token" | "hmac_secret"
  // | "basic_password" | "bearer_token" | "client_secret" | "private_key"
  kind          String
  // AES-256-GCM payload: iv(12) || authTag(16) || ciphertext, all base64
  ciphertext    String
  // HKDF context — included in additional-authenticated-data so a credential
  // moved to another integration cannot be decrypted.
  keyContext    String      @default("")
  // Optional non-secret metadata about this credential (token type, account id,
  // refresh URL hint, etc.). NEVER store secret values here.
  meta          Json        @default("{}")
  expiresAt     DateTime?
  refreshAfter  DateTime?
  rotatedAt     DateTime?
  rotatedFrom   String?     // previous credential id chain for audit
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([integrationId, kind])
  @@index([integrationId])
  @@index([expiresAt])
}

model IntegrationSyncState {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  resourceId    String      // matches manifest.capabilities.syncs[].id
  cursor        String?     // opaque (timestamp / page token / etag)
  fullSyncAt    DateTime?   // last successful full sync
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastErrorAt   DateTime?
  lastError     String?
  recordsTotal  Int         @default(0)
  recordsLast   Int         @default(0)
  status        String      @default("idle") // idle | running | error | paused
  schedule      String?     // cron override (manifest provides default)
  enabled       Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([integrationId, resourceId])
  @@index([integrationId])
  @@index([status])
}

model IntegrationEvent {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  // direction: "inbound" (webhook received) | "outbound" (we sent / fired)
  direction     String
  // type: e.g. "webhook.invoice.paid" | "sync.run" | "action.invoke" | "auth.refresh"
  type          String
  status        String      @default("pending") // pending | delivered | failed | replayed
  payload       Json        @default("{}")
  headers       Json        @default("{}")
  signatureValid Boolean?   // null when not applicable
  externalId    String?     // for idempotency on inbound webhooks
  attemptCount  Int         @default(0)
  nextAttemptAt DateTime?
  lastError     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([integrationId, externalId])
  @@index([integrationId])
  @@index([direction, status])
  @@index([createdAt])
}

model IntegrationRun {
  id              String      @id @default(cuid())
  integrationId   String
  integration     Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  actionId        String      // matches manifest.capabilities.actions[].id
  status          String      @default("pending") // pending | running | success | error | timeout
  invokedBy       String      @default("user")    // user | agent | sync | webhook | system
  agentSessionId  String?
  userId          String?
  input           Json        @default("{}")
  output          Json?
  error           String?
  httpStatus      Int?
  durationMs      Int?
  idempotencyKey  String?
  startedAt       DateTime    @default(now())
  completedAt     DateTime?

  @@unique([integrationId, idempotencyKey])
  @@index([integrationId])
  @@index([status])
  @@index([startedAt])
}

model ExternalRecord {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  resourceId    String      // matches manifest.capabilities.syncs[].id
  externalId    String      // ID in the foreign system
  data          Json        @default("{}")
  fingerprint   String      @default("") // sha256 of canonicalized data, used to skip no-ops
  // When mapped to a Bidwright entity, format "Customer:abc123" / "Project:xyz".
  mappedTo      String?
  fetchedAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([integrationId, resourceId, externalId])
  @@index([integrationId])
  @@index([mappedTo])
  @@index([fetchedAt])
}
