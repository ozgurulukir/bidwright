<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Bidwright Desktop spawns child processes (the Next.js standalone
	     server and embedded Postgres binaries) and they need to inherit
	     enough sandbox to read their bundled files + bind localhost
	     ports. Hardened-runtime entitlements below grant only what the
	     Electron + child-process startup actually needs — JIT for the
	     V8 engine, child-process spawning, and unsigned-executable
	     mapping for the embedded-postgres binary that ships unsigned. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<key>com.apple.security.inherit</key>
	<true/>
</dict>
</plist>
