DATABASE_URL=postgresql://bidwright:bidwright@localhost:5432/bidwright
REDIS_URL=redis://localhost:6379
DATA_DIR=./data/bidwright-api
DEFAULT_ORG_ID=org-bidwright-seed
API_PORT=4001
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001

WEB_PUBLIC_PORT=3000
API_PUBLIC_PORT=3001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=snowflake-arctic-embed
EMBEDDING_DIMENSIONS=1024

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Bidwright

# Optional. If unset, Bidwright generates a fresh 32-byte key on first
# boot and persists it under ${DATA_DIR}/secrets/integrations.key. Set
# this only when you want to pin the key from a vault / secret manager.
INTEGRATIONS_ENCRYPTION_KEY=

# ── Deployment shape ──────────────────────────────────────────────
# desktop = single-user Electron-style; server = Docker self-host or
# hosted SaaS. Multitenant adds per-user bwrap CLI sandboxes (server
# mode only).
BIDWRIGHT_MODE=desktop
BIDWRIGHT_MULTITENANT=false
AGENT_HOME_ROOT=/data/agent-home

# ── Workspace storage (project files survive host restarts and follow
# ── users across hosts in a stateless api pool). Leave provider unset to
# ── keep workspaces on local disk only. Same env shape covers Cloudflare
# ── R2, AWS S3, and a self-hosted MinIO (the `workspace-storage` profile
# ── in docker-compose.yml).
#
# Cloudflare R2 example:
#   WORKSPACE_STORAGE_PROVIDER=s3
#   WORKSPACE_S3_BUCKET=bidwright-workspaces
#   WORKSPACE_S3_REGION=auto
#   WORKSPACE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   WORKSPACE_S3_ACCESS_KEY_ID=<R2 access key>
#   WORKSPACE_S3_SECRET_ACCESS_KEY=<R2 secret key>
#   WORKSPACE_S3_FORCE_PATH_STYLE=false
#
# Self-hosted MinIO (using the bundled compose profile):
#   docker compose --profile workspace-storage up -d minio
#   # then create the bucket once (admin@minio:9001 or `mc mb`)
#   WORKSPACE_STORAGE_PROVIDER=s3
#   WORKSPACE_S3_BUCKET=bidwright
#   WORKSPACE_S3_REGION=us-east-1
#   WORKSPACE_S3_ENDPOINT=http://minio:9000
#   WORKSPACE_S3_ACCESS_KEY_ID=bidwright
#   WORKSPACE_S3_SECRET_ACCESS_KEY=bidwright-dev-only
#   WORKSPACE_S3_FORCE_PATH_STYLE=true
WORKSPACE_STORAGE_PROVIDER=
WORKSPACE_S3_BUCKET=
WORKSPACE_S3_REGION=auto
WORKSPACE_S3_ENDPOINT=
WORKSPACE_S3_ACCESS_KEY_ID=
WORKSPACE_S3_SECRET_ACCESS_KEY=
WORKSPACE_S3_PREFIX=bidwright/workspaces
WORKSPACE_S3_FORCE_PATH_STYLE=false
